{
  "manifest_version": 3,
  "name": "Broadcast Form Auto",
  "version": "1.0",
  "description": "Streamline bulk form submissions by automatically sending Excel data to multiple web forms with speed and accuracy.",
  "icons": {
    "16": "icons/16x16.png",
    "32": "icons/32x32.png",
    "192": "icons/192x192.png",
    "512": "icons/512x512.png"
  },
  "action": {
    "default_title": "Open Broadcast Form Auto",
    "default_icon": {
      "16": "icons/16x16.png",
      "32": "icons/32x32.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "cookies",
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "sidePanel"
  ],
  "side_panel": {
    "default_path": "index.html"
  },
  "host_permissions": [
    "https://anstoreautomated.biz.id/*"
  ],
  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ]
}